{
  "permissions": {
    "deny": [
      "Bash(rm*run.lock*)",
      "Bash(*rm*run.lock*)"
    ]
  },
  "hooks": {
    "SessionStart": [
      {
        "matcher": "",
        "hooks": [{"type": "command", "command": "bash tools/HyperMeta-Ecstasy/hooks/sessionstart.sh"}]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Edit",
        "hooks": [{"type": "command", "command": "bash tools/HyperMeta-Ecstasy/hooks/pretooluse_edit.sh"}]
      },
      {
        "matcher": "Grep",
        "hooks": [{"type": "command", "command": "bash tools/HyperMeta-Ecstasy/hooks/pretooluse_grep.sh"}]
      },
      {
        "matcher": "Write",
        "hooks": [{"type": "command", "command": "bash tools/HyperMeta-Ecstasy/hooks/pretooluse_write.sh"}]
      },
      {
        "matcher": "Bash",
        "hooks": [{"type": "command", "command": "bash tools/HyperMeta-Ecstasy/hooks/pretooluse_bash.sh"}]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {"type": "command", "command": "bash tools/HyperMeta-Ecstasy/hooks/posttooluse_bash.sh"},
          {"type": "command", "command": "bash tools/HyperMeta-Ecstasy/hooks/posttooluse_pipeline_kb.sh"}
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "matcher": "",
        "hooks": [{"type": "command", "command": "bash tools/HyperMeta-Ecstasy/hooks/userpromptsubmit.sh"}]
      }
    ],
    "PreCompact": [
      {
        "matcher": "",
        "hooks": [{"type": "command", "command": "bash tools/HyperMeta-Ecstasy/hooks/precompact.sh"}]
      }
    ],
    "Stop": [
      {
        "matcher": "",
        "hooks": [{"type": "command", "command": "bash tools/HyperMeta-Ecstasy/hooks/stop.sh"}]
      }
    ]
  }
}
