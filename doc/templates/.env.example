# Project environment template.
# Copy to <repo-root>/.env and fill host/provider-specific values.
# Defaults belong here, not as inline code fallbacks.
# Runtime code must read these keys through fail-fast env accessors.

GEMINI_API_KEY=
GROQ_API_KEY=
OPENROUTER_API_KEY=
CEREBRAS_API_KEY=
MISTRAL_API_KEY=
NVIDIA_API_KEY=
OPENCODE_API_KEY=
AIHUBMIX_API_KEY=
KILO_API_KEY=
BASE_ROOT_PATH=  # optional local-path redaction marker; leave blank unless needed
PROJECT_ROOT=<repo-root>
# SECRETS ABOVE THIS LINE - precommit hook ensures the values above can never be committed to git
COMPOSITION_OUTPUT_DIR=${PROJECT_ROOT}/src/output
COMPOSITION_METRICS_DIR=${COMPOSITION_OUTPUT_DIR}/metrics
METRICS_DIR=${COMPOSITION_METRICS_DIR}
HME_RUNTIME_DIR=${PROJECT_ROOT}/tools/HME/runtime
HME_METRICS_DIR=${HME_RUNTIME_DIR}/metrics
HME_STATE_DIR=${HME_RUNTIME_DIR}/state
SRC_SCRIPTS_DIR=${PROJECT_ROOT}/src/scripts
HME_SCRIPTS_DIR=${PROJECT_ROOT}/tools/HME/scripts
SRC_TESTS_DIR=${PROJECT_ROOT}/src/tests
HME_TESTS_DIR=${PROJECT_ROOT}/tools/HME/tests
# RAG walker / file watcher exclusions — all comma-separated.
# HME_IGNORE_DIRS: directory basenames (merged with .gitignore bare dirs automatically).
# HME_IGNORE_FILES: exact filenames (lock files etc).
# HME_IGNORE_EXTS: file extensions to skip in the watcher (leading dot optional).
# HME_RAG_MAX_FILE_SIZE_KB: files larger than this are skipped by the walker.
HME_IGNORE_DIRS=node_modules,.git,target,dist,build,__pycache__,.cache,pkg,wasm-pack-out,.claude,venv,.venv,env,.env,runtime,.idea,.vscode,.next,coverage,.nyc_output,.turbo,.github,metrics,output,tmp,lab,tools/omniroute
HME_IGNORE_FILES=pnpm-lock.yaml,package-lock.json,yarn.lock,Cargo.lock,poetry.lock,composer.lock
HME_IGNORE_EXTS=.log,.lock,.json,.jsonl,.md,.wav,.mid,.csv,.png,.jpg,.gif,.mp3,.ogg,.gguf,.safetensors,.bin,.pt,.pth,.ckpt,.h5,.onnx,.tflite,.pb,.gz,.tar,.zip,.xz,.zst,.bz2,.manifest,.txn,.lance
HME_RAG_MAX_FILE_SIZE_KB=40
HME_AUTOLAUNCH_LLAMA=0
# Launcher used to spawn llama-server directly in parallel with the worker's
# daemon supervisor. That produced a bind-race: both tried to claim :8081,
# one won, the other silently crashed with "couldn't bind". The daemon
# supervisor in tools/HME/mcp/llamacpp_daemon.py is now the only spawner —
# it adopts externals if present, otherwise spawns on demand. Flip back to 1
# only if the daemon fails to auto-spawn (it shouldn't).
ANTHROPIC_BASE_URL=http://127.0.0.1:9099
# ══════════════════════════════════════════════════════════════════════
# HME configuration — EVERY value read by HME must be declared here.
# No silent fallbacks. hme_env.ENV.require() fails fast on missing keys.
# ══════════════════════════════════════════════════════════════════════

# Models — all local, all under MODEL_DIR
HME_MODEL_DIR=${PROJECT_ROOT}/tools/models
#   LLM (GGUF, served by llama-server via daemon)
HME_MODEL_ARBITER=${HME_MODEL_DIR}/phi-4-Q4_K_M.gguf
HME_MODEL_CODER=${HME_MODEL_DIR}/qwen3-coder-30b-Q4_K_M.gguf
#   RAG (SentenceTransformer / mxbai, loaded by shim)
HME_MODEL_TEXT_EMBED=${HME_MODEL_DIR}/qwen3-embedding-0.6b
HME_MODEL_CODE_EMBED=${HME_MODEL_DIR}/bge-code-v1
HME_MODEL_RERANKER=${HME_MODEL_DIR}/mxbai-rerank-base-v2
#   Audio (EnCodec + CLAP, loaded by perceptual_engines)
HME_MODEL_ENCODEC=${HME_MODEL_DIR}/encodec-24khz.th
HME_MODEL_CLAP=${HME_MODEL_DIR}/clap-630k-audioset.pt

# Arbiter v6 (phi-4 Q4_K_M + v6 LoRA baked in)
# Backend: llama-server (Vulkan) with OpenAI chat-completions.
#   arbiter → :8080  (Vulkan1 / nvidia-smi GPU0)
#   coder   → :8081  (Vulkan2 / nvidia-smi GPU1)
HME_ARBITER_BACKEND=llamacpp
HME_ARBITER_MODEL=hme-arbiter
HME_ARBITER=${HME_MODEL_ARBITER}
HME_ARBITER_PORT=8080
HME_ARBITER_VULKAN=Vulkan1
HME_ARBITER_CTX=4096
HME_ARBITER_TIMEOUT=120

# Coder (qwen3-coder:30b Q4_K_M)
HME_CODER_ALIAS=qwen3-coder:30b
HME_CODER=${HME_MODEL_CODER}
HME_CODER_PORT=8081
HME_CODER_VULKAN=Vulkan2
HME_CODER_CTX=8192

# Model aliases consumed by synthesis_llamacpp / agent_local
HME_CODER_MODEL=qwen3-coder:30b
HME_REASONING_MODEL=qwen3-coder:30b

# Worker watchdog: 240s default too short for ~500-file index_directory (kept hitting hard-kill).
HME_TOOL_HARDKILL_S=600

# Comment-bloat thresholds: single source of truth read by both pretooluse_edit.sh and scripts/audit-comment-bloat.py.
COMMENT_BLOAT_WARN=3
COMMENT_BLOAT_FAIL=5
COMMENT_BLOAT_LONG_LINE=90

# Inference proxy (intercepts Claude API calls for HME observability)
HME_PROXY_PORT=9099
HME_PROXY_ENABLED=1 # re-enabled: upstream timeout bumped 120s→1800s (30min) to handle large-transcript `claude --resume` calls; was tripping the emergency valve repeatedly
HME_DUMP_SYSTEM_PROMPT=1 # set to 1 to enable dump_system middleware (writes pre/post payload + system to tmp/ -- diff to verify HME mutations)
HME_FILTER_TOOLS_DROP=mcp__claude_ai_Google_Drive__authenticate,mcp__claude_ai_Google_Drive__complete_authentication,RemoteTrigger,PushNotification,CronCreate,CronDelete,CronList,EnterWorktree,ExitWorktree,AskUserQuestion,EnterPlanMode,ExitPlanMode,NotebookEdit,TeamCreate,TeamDelete,ScheduleWakeup,SendMessage,Skill,TaskOutput,TaskStop,TaskUpdate,TaskGet,TaskCreate,TaskList # comma-separated tool names dropped from payload.tools. WebSearch/WebFetch/Monitor kept (heavily used). Bash, Agent, and TodoWrite (and to a lesser extent, Read, WebFetch, and WebSearch) are the only remaining long ones that need abbreviated rewrites.
HME_PROXY_UPSTREAM_HOST=api.anthropic.com
HME_PROXY_UPSTREAM_PORT=443
HME_PROXY_UPSTREAM_TLS=1
CLAUDE_PROJECT_DIR=${PROJECT_ROOT}

# Inference endpoints
HME_LLAMACPP_ARBITER_URL=http://127.0.0.1:8080
HME_LLAMACPP_CODER_URL=http://127.0.0.1:8081
HME_LLAMACPP_DAEMON_URL=http://127.0.0.1:7735
HME_LLAMACPP_DAEMON_PORT=7735
# Wall-clock ceiling for the free-tier reasoning cascade. INVARIANT: must
# be ≥ 3× the longest per-provider timeout (NVIDIA is 120s) or the cascade
# only ever tries one provider before the deadline fires. 45s used to be
# the default and caused silent exhaustion when Anthropic was rate-limited.
HME_REASONING_WALL_SECS=300
HME_SELFTEST_WARMUP_WAIT=30

# Consecutive transport failures before worker_client.js / _safe_curl surface
# streak warnings to hme-errors.log (→ LIFESAVER banner). Shared threshold so
# both components move in lockstep if sensitivity is ever retuned.
HME_STREAK_WARN=5

# Warm KV / context sizing
HME_KEEP_ALIVE=-1
HME_NUM_CTX_30B=32768
HME_NUM_CTX_4B=32768
HME_REASONER_WARM=0

# Daemon supervisor (all llama.cpp timeouts live in daemon)
HME_LLAMA_SERVER_BIN=${PROJECT_ROOT}/tools/bin/llama-server
HME_LLAMA_LOG_DIR=${PROJECT_ROOT}/log
HME_LLAMA_HEALTH_TIMEOUT=3
HME_LLAMA_RESTART_COOLDOWN=30

# PyTorch CUDA allocator: expandable_segments avoids fragmentation that
# turned a fresh ~5 GiB embedder request into a 48 GiB allocation failure
# during reindex. MUST be set before torch's first CUDA init or it is
# silently ignored. hme_env loads .env early enough; the proxy supervisor
# also exports it via children.js when it spawns worker/daemon.
PYTORCH_CUDA_ALLOC_CONF=expandable_segments:True

# RAG / embedding
# OMP_NUM_THREADS is consumed by native BLAS/OpenMP libraries after .env export.
OMP_NUM_THREADS=12
HME_RAG_GPU=0
HME_RAG_VULKAN=Vulkan1
HME_RAG_MIN_FREE_GB=1.5
HME_CODE_EMBED_BATCH=8
HME_AUDIO_GPU=1
HME_AUDIO_VULKAN=Vulkan2

# RAG model stack (activated 2026-04-15):
#   text  → Qwen3-Embedding-0.6B    (1024 dim, Apache 2.0, MTEB English 70.70)
#   code  → BAAI/bge-code-v1        (1536 dim, Apache 2.0, CoIR 81.77)
#   rerank→ mxbai-rerank-base-v2    (Apache 2.0, BEIR 55.57, 500M)
# Model paths defined above in the Models section (HME_MODEL_*).
# Backend "default" uses torch fp16 directly — Qwen3-Embedding has no ONNX export.
HME_RAG_BACKEND=default
# Storage root for the lance tables — code_chunks, knowledge, symbols.
HME_RAG_DB_PATH=${PROJECT_ROOT}/tools/HME/KB
# Global KB (cross-project pattern store). Formerly lived at ~/.claude/mcp/HME/global_kb
# via the now-deleted home-dir MCP symlink; project-local and HME-owned as of
# the MCP decoupling.
HME_GLOBAL_KB_PATH=${PROJECT_ROOT}/tools/HME/KB/global_kb

# VRAM monitor
HME_VRAM_POLL_S=60
HME_VRAM_MAX_SAMPLES=1000

# Evolution / cognition windows
HME_BLINDSPOT_WINDOW=10
HME_CRYSTALLIZE_MIN_ENTRIES=3
HME_CRYSTALLIZE_MIN_ROUNDS=3

# Ops locks
HME_TRAINING_LOCK=${HME_RUNTIME_DIR}/hme-training.lock


# HME_DOMINANCE=1 was a "rewriter" that translated AUTO-COMPLETENESS,
# LIFESAVER, EXHAUST PROTOCOL Stop-hook deny messages into cryptic
# placeholders ("auto-continue queued", "auto-recover queued", etc).
# In practice this hid the actionable directives from the agent --
# the user repeatedly screamed "auto-completeness still didn't fire"
# because the rewriter was stripping the directive content. Now off.
# The original Stop-hook denies (with their full guidance text) reach
# the agent unmodified.
HME_DOMINANCE=0
# HME_WORKER_TRANSPORT: how the proxy talks to the worker for tool +
# enrichment dispatch. Independent of HME_DISPATCH_MODE (which governs
# the BUDDY queue, not the worker queue).
#   http     (default)  Localhost HTTP. Lowest latency. Vulnerable to
#                       socket-level bugs (ECONNRESET, half-open
#                       sockets) and loses in-flight requests if the
#                       worker is SIGKILLed mid-call.
#   hybrid              FS for POST /tool/*, /enrich, /enrich_prompt,
#                       /audit (the endpoints worker_queue.py drains).
#                       Other endpoints (GET /tools/list, /health,
#                       /version, /transcript, etc.) stay on HTTP.
#                       Buys: SIGKILL-survivable tool calls (job stays
#                       in tmp/hme-worker-queue/, next worker boot's
#                       watcher picks it up); audit trail; no socket
#                       lifecycle issues. Costs: ~1-5ms FS tax per call
#                       (negligible vs typical tool-call wall-time).
#                       MCP wire spec at the boundary is unchanged —
#                       Claude Code still talks HTTP/SSE to /mcp/*.
HME_WORKER_TRANSPORT=hybrid
# Overdrive -- canonical semantics live in doc/infra/overdrive_modes.md
OVERDRIVE_MODE=1
OVERDRIVE_VIA_SUBAGENT=0
HME_OMNIROUTE_PORT=20128
# HME_OMNIROUTE_OFF=1
# HME_OMNIROUTE_PROVIDER=cx
# OVERDRIVE_THINK_BUDGET=128000
OVERDRIVE_TIMEOUT=300
# OVERDRIVE_CHAIN=claude-opus-4-7,claude-sonnet-4-6,claude-haiku-4-5-20251001
# OVERDRIVE_RATE_LIMIT_COOLDOWN: seconds to skip a model after it rate-limits.
# Prevents the N×2 retry tax during sustained rate-limit windows.
OVERDRIVE_RATE_LIMIT_COOLDOWN=60
HME_REPLACE_SYSTEM_PROMPT=1 # replace_system.js uses doc/templates/canonical-system-prompt.md as the system prompt

# thinking_rewrite middleware: force visible plaintext thinking
# (Claude Code IDE only sends thinking.type=adaptive which redacts)
HME_PROXY_FORCE_THINKING=1
HME_PROXY_THINKING_DISPLAY=summarized
CALL_LOG_PIPELINE_CAPTURE_STREAM_CHUNKS=true
CALL_LOG_PIPELINE_MAX_SIZE_KB=4096

# Proxy compaction controls.
# Policy: do not compact below ~80% of the resolved model input budget.
# Gear 1: stale large tool_result microcompaction only.
# Gear 2: optional summaries/session notes only; no whole-message dropping.
# Gear 3: whole-message dropping/emergency tail elision only near true context danger.
HME_PROXY_LOCAL_SUMMARY=0
HME_PROXY_COMPACT_BYTES=3000000

# Keep long histories unless high-water context pressure is real.
HME_PROXY_STALE_TOOL_KEEP_TURNS=200
HME_PROXY_COMPACT_KEEP_MIN=200
HME_PROXY_CONTEXT_FRACTION=0.99
HME_PROXY_CONTEXT_BYTES_PER_TOKEN_EST=
HME_PROXY_CONNRESET_RETRY=1
HME_PROXY_REMAINING_FRACTION=0.85
HME_PROXY_CONTEXT_SIGNAL_REMAINING_FRACTION=0.08

HME_PROXY_COMPACT_START_FRACTION=0.88
HME_PROXY_COMPACT_GEAR1_TARGET=0.88
HME_PROXY_COMPACT_GEAR2_TARGET=0.94
HME_PROXY_COMPACT_GEAR3_TARGET=0.985
HME_PROXY_COMPACT_GEAR1_END=0.94
HME_PROXY_COMPACT_GEAR2_END=0.985
HME_PROXY_COMPACT_GEAR3_END=2
HME_ENV_FAILFAST_TEMPLATE=doc/templates/.env.example
