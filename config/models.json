{
  "_meta": {
    "version": "1.0.0-draft",
    "description": "OVERDRIVE_MODE=1 team-role model registry. Models ranked into 5 effort tiers (E5-E1). Within each tier: free models first (OpenCode Zen free + cascade free from various direct APIs), then subscription (OpenCode Go), then usage-based (OpenCode Zen non-free).",
    "providers": {
      "opencode": {
        "note": "Zen (free tier and usage-based)"
      },
      "opencode_go": {
        "note": "Go subscription, $10/month"
      },
      "anthropic": {
        "note": "Claude/Anthropic subcription."
      },
      "codex": {
        "note": "ChatGPT/OpenAI subcription."
      }
    },
    "toprank_rationale": {
      "E5": "gpt5.5 frontier with abundant usage credits."
    }
  },
  "providers_to_skip": {
    "description": "Pause provider usage in case of credit shortage.",
    "providers": [
      "anthropic"
    ]
  },
  "ranking_rules": {
    "description": "Per-tier: rank each cost type independently by tier_score descending (subscription > free > usage).",
    "cost_order": [
      "subscription",
      "free",
      "usage"
    ]
  },
  "team_subagent_routing_rules": {
    "description": "Driver can specify tier level (E1-E5) of subagents where Driver's routring works like this: if E5, goes to whichever Team lead has the least used context, or whichever Team Lead is available, or fallback to the following E4 logic if both Team Leads unavailable. If E4, goes to whichever Purple Partner has least used context, or whichever Purple Partner is available, or whichever E4 stage crew is available (never wait). For E1-E3, these go to either of the two stage crew per tier has the least used context, or whichever is available, or the next lowest tier, etc.  Team Lead subagent routing goes like this: E4 & E5: Purple partner of same team, or E4 stagecrew. E1-E3: appropriately tiered stage crew, falling to lower tiers when desired tier unavailble.  Purple Partner subagent routing: E4 & E5: Purple partner of opposing team, or E4 stagecrew. E1-E3: appropriately tiered stage crew, falling to lower tiers when desired tier unavailble.  Stage Crew subagent routing: Only allowed for E3 & E4 stage crew (E1-E3 agents blocked from using Agent tool), capped at level of originating stage crew. Routes to appropriately tiered stage crew, falling to lower tiers when desired tier unavailble."
  },


