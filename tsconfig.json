{
  "compilerOptions": {
    "allowJs": true,
    "checkJs": true,
    "noEmit": true,
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "node",
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "skipLibCheck": true,
    "lib": ["ES2022"],
    "types": ["node"]
  },
  "include": [
    "src/composers/**/*.js",
    "src/fx/**/*.js",
    "src/types/**/*.d.ts"
  ],
  "exclude": ["node_modules", "test", "coverage", "csv_maestro", "src/utils/**", "src/time/**", "src/writer/**", "src/rhythm/**"]
}
