{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Polychron Feedback Topology",
  "description": "A machine-readable map of the closed loops, firewalls, and emergence boundaries governing the polychron composition engine.",
  "firewalls": {
    "CONDUCTOR_BLINDNESS": {
      "description": "Cross-layer coordination affects local probability but cannot inject signals directly into the conductor. Conductor is insulated from structural micro-adjustments.",
      "boundaryType": "isolating-membrane"
    },
    "SIGNAL_DELAY": {
      "description": "Cross-layer queries the conductor via conductorSignalBridge, introducing a mandatory, one-beat delayed snapshot requirement.",
      "boundaryType": "latency-barrier"
    },
    "REGISTRY_DAMPENING": {
      "description": "All closed-loop feedback mechanisms must enroll through feedbackRegistry and pipelineCouplingManager to prevent resonant feedback cascades.",
      "boundaryType": "dampener"
    }
  },
