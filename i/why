#!/usr/bin/env bash
# i/why — explain something the system did or is in.
#   i/why <invariant-id>          full provenance + rationale for an invariant
#   i/why mode=block              most recent hook/policy block + how to opt out
#   i/why mode=state              current onboarding state + transition history
#   i/why mode=verifier <name>    explain a specific HCI verifier (status, history, source)
#   i/why mode=hci-drop           find the most recent HCI regression + which verifier(s) caused it
#   i/why mode=hook               recent hook activity (broader than mode=block)
#   i/why mode=verifier-utility   meta-meta: which verifiers always-PASS, flap, or have noisy scores (Horizon VI)
#   i/why "<free-text>"           Tier 2 — deterministic retrieval (grep + KB + activity)
#   i/why "<free-text>" --deep    Tier 3 — queue subagent synthesis on top of Tier 2 packet
SCRIPT_DIR="$(dirname "$0")/../scripts/hme"
python3 "$(dirname "$0")/../scripts/hme/tool-usage-log.py" why "$@" &

# Mode dispatch — keep first-arg-as-invariant-id as the historical default.
for arg in "$@"; do
  case "$arg" in
    mode=block)     exec python3 "$SCRIPT_DIR/why-block.py" "$@" ;;
    mode=state)     exec python3 "$SCRIPT_DIR/why-state.py" "$@" ;;
    mode=verifier)  exec python3 "$SCRIPT_DIR/why-verifier.py" "$@" ;;
    mode=hci-drop)  exec python3 "$SCRIPT_DIR/why-hci-drop.py" "$@" ;;
    mode=hook)      exec python3 "$SCRIPT_DIR/why-hook.py" "$@" ;;
    mode=verifier-utility) exec python3 "$SCRIPT_DIR/why-verifier-utility.py" "$@" ;;
    mode=verifier-coverage) exec python3 "$SCRIPT_DIR/why-verifier-coverage.py" "$@" ;;
    mode=verifier-drift) exec python3 "$SCRIPT_DIR/why-verifier-drift.py" "$@" ;;
    mode=kb-graph) exec python3 "$SCRIPT_DIR/why-kb-graph.py" "$@" ;;
    mode=kb-context) exec python3 "$SCRIPT_DIR/why-kb-context.py" "$@" ;;
    mode=predict) exec python3 "$SCRIPT_DIR/why-predict.py" "$@" ;;
    mode=conscience) exec python3 "$SCRIPT_DIR/why-conscience.py" "$@" ;;
    mode=causality) exec python3 "$SCRIPT_DIR/why-causality.py" "$@" ;;
    mode=fractal-shape) exec python3 "$SCRIPT_DIR/why-fractal-shape.py" "$@" ;;
    mode=architecture-snapshot) exec python3 "$SCRIPT_DIR/why-architecture-snapshot.py" "$@" ;;
    mode=search)    exec python3 "$SCRIPT_DIR/why-search.py" "$@" ;;
    mode=freeze)
      _ARGS=()
      for _a in "$@"; do
        [ "$_a" = "mode=freeze" ] && continue
        _ARGS+=("$_a")
      done
      exec python3 "$SCRIPT_DIR/freeze-check.py" "${_ARGS[@]}"
      ;;
  esac
done

# Tier 1: try as invariant ID first. If unknown, fall through to Tier 2
# search retrieval. Distinguishes by checking if first arg looks like an
# invariant ID (kebab-case, no spaces). Multi-word questions go to search.
if [ "$#" -ge 1 ]; then
  FIRST="$1"
  # Multi-word or contains spaces or first arg has special chars → search.
  if [ "$#" -gt 1 ] || [[ "$FIRST" == *" "* ]] || [[ "$FIRST" == *"?"* ]]; then
    exec python3 "$SCRIPT_DIR/why-search.py" "$@"
  fi
fi
exec python3 "$SCRIPT_DIR/why-invariant.py" "$@"
