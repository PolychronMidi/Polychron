#!/usr/bin/env bash
# HME review — invokes scripts/hme-cli.js against the worker (127.0.0.1:9098).
# Usage: i/review [mode=digest|forget|changes] [section_a=N] [section_b=N] [critique=true] ...
_HME_CLI="$(dirname "$0")/../scripts/hme-cli.js"
[ -f "$_HME_CLI" ] || { echo "i/: scripts/hme-cli.js missing at $_HME_CLI — run scripts/setup-mcp.sh after cloning" >&2; exit 1; }
exec node "$_HME_CLI" review "$@"
