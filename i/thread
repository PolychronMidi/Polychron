#!/usr/bin/env bash
# i/thread — persistent subagent session. Routes HME reasoning tasks
# (review reflection, OVERDRIVE cascade, suggest_evolution) to a single
# long-lived claude session instead of fresh-spawn-per-task. Context
# accumulates across tasks, so task N can reference insights from task
# N-1. User monitors the session by opening its sid in a VSCode Claude
# Code tab.
#
# Usage:
#   i/thread init                 # create a new persistent session; prints sid to resume in VSCode
#   i/thread send <prompt-json>   # dispatch one task to the session (reads prompt from queue json)
#   i/thread status               # show current sid + queue counts
#   i/thread stop                 # clear sid; future subagent calls revert to fresh-spawn Agent path
#
# When active (sid file present), synthesis_reasoning.py emits a Bash-
# dispatched sentinel instead of an Agent-dispatched one; the main agent
# transparently invokes `i/thread send` per queued task.
set -euo pipefail

_REPO_ROOT="${CLAUDE_PROJECT_DIR:-/home/jah/Polychron}"
_SID_FILE="$_REPO_ROOT/tmp/hme-thread.sid"
_RESULTS_DIR="$_REPO_ROOT/tmp/hme-subagent-results"
_QUEUE_DIR="$_REPO_ROOT/tmp/hme-subagent-queue"
_DONE_DIR="$_QUEUE_DIR/done"

_init_prompt=$(cat <<'EOF'
You are the persistent subagent thread for the Polychron codebase. Multiple
reasoning tasks will arrive across this session, each formatted as a user
message with a structured prompt. Accumulate context across tasks — when a
new task references concepts or code from an earlier task, draw on the
history. Reply with grounded concise reasoning; cite file:line where
applicable. Do NOT attempt to run tools; just reason.
EOF
)

cmd="${1:-help}"

case "$cmd" in
  init)
    if [ -f "$_SID_FILE" ]; then
      echo "thread already active: sid=$(cat "$_SID_FILE")" >&2
      exit 1
    fi
    mkdir -p "$(dirname "$_SID_FILE")"
    # HME_THREAD_CHILD=1 prevents the spawned claude from re-entering
    # our own stop hooks — it'd otherwise auto-loop on AUTO-COMPLETENESS
    # INJECT and burn tokens on synthetic stop-hook traffic.
    _out=$(HME_THREAD_CHILD=1 claude -p --output-format json "$_init_prompt")
    # `claude --output-format json` emits a JSON ARRAY of message events,
    # not a single object. Find the system/init event and read its
    # session_id field.
    _sid=$(printf '%s' "$_out" | python3 -c "
import sys, json
try:
    data = json.loads(sys.stdin.read())
    if isinstance(data, list):
        for ev in data:
            if isinstance(ev, dict) and ev.get('type') == 'system' and ev.get('subtype') == 'init':
                sid = ev.get('session_id', '')
                if sid:
                    print(sid)
                    sys.exit(0)
        for ev in data:
            if isinstance(ev, dict) and ev.get('session_id'):
                print(ev['session_id'])
                sys.exit(0)
        # Array parsed cleanly but no init event AND no session_id key
        # found. Diagnose specifically so caller distinguishes from a
        # parse error vs an empty/missing-field array.
        print('NO_SESSION_ID: parsed list of '
              + str(len(data)) + ' events with no init/session_id',
              file=sys.stderr)
    elif isinstance(data, dict):
        print(data.get('session_id', ''))
except Exception as e:
    print(f'PARSE_ERROR: {type(e).__name__}: {e}', file=sys.stderr)
" 2>&1)
    if [ -z "$_sid" ] || [[ "$_sid" == PARSE_ERROR* ]] || [[ "$_sid" == NO_SESSION_ID* ]]; then
      echo "failed to extract session_id ($_sid):" >&2
      echo "$_out" >&2
      exit 1
    fi
    printf '%s\n' "$_sid" > "$_SID_FILE"
    printf 'thread initialized: sid=%s\n' "$_sid"
    printf 'open VSCode Claude Code → resume session %s to monitor\n' "$_sid"
    # Emit activity for coverage telemetry.
    if [ -x "$_REPO_ROOT/tools/HME/activity/emit.py" ]; then
      PROJECT_ROOT="$_REPO_ROOT" python3 "$_REPO_ROOT/tools/HME/activity/emit.py" \
        --event=thread_init --sid="$_sid" >/dev/null &
    fi
    ;;

  send)
    if [ -z "${2:-}" ]; then
      echo "usage: i/thread send <prompt-json-file>" >&2
      exit 2
    fi
    if [ ! -f "$_SID_FILE" ]; then
      echo "no active thread — run: i/thread init" >&2
      exit 1
    fi
    _prompt_file="$2"
    if [ ! -f "$_prompt_file" ]; then
      echo "prompt file missing: $_prompt_file" >&2
      exit 1
    fi
    _sid=$(cat "$_SID_FILE")
    _req_id=$(basename "$_prompt_file" .json)
    _prompt=$(jq -r '.prompt' "$_prompt_file")
    if [ -z "$_prompt" ] || [ "$_prompt" = "null" ]; then
      echo "empty or missing .prompt in $_prompt_file" >&2
      exit 1
    fi

    # Route through persistent session. Output streams directly to the
    # main agent's tool_result so it reads like any Bash response.
    # HME_THREAD_CHILD=1 prevents recursive stop-hook firing inside the
    # spawned claude session.
    _out=$(HME_THREAD_CHILD=1 claude --resume "$_sid" -p "$_prompt")
    _rc=$?
    if [ $_rc -ne 0 ]; then
      echo "claude --resume exited $_rc" >&2
      exit $_rc
    fi

    # Mirror the subagent_bridge.js behavior so downstream consumers of
    # hme-subagent-results/ see thread-routed results in the same place
    # Agent-routed ones land.
    mkdir -p "$_RESULTS_DIR"
    _ts=$(date +%s)
    python3 -c "
import json, sys
obj = {'req_id': '$_req_id', 'text': sys.stdin.read(),
       'captured_at': $_ts, 'via': 'thread'}
print(json.dumps(obj))
" <<<"$_out" > "$_RESULTS_DIR/$_req_id.json"

    # Move queue entry to done/ for audit trail.
    mkdir -p "$_DONE_DIR"
    if [ -f "$_prompt_file" ]; then
      mv "$_prompt_file" "$_DONE_DIR/$_req_id.json" || true
    fi

    # Emit activity so thread-routed reasoning shows in blindspots/coverage.
    if [ -x "$_REPO_ROOT/tools/HME/activity/emit.py" ]; then
      PROJECT_ROOT="$_REPO_ROOT" python3 "$_REPO_ROOT/tools/HME/activity/emit.py" \
        --event=thread_dispatch --req_id="$_req_id" \
        --bytes="${#_out}" >/dev/null &
    fi

    # Surface the response inline so the main agent can consume.
    printf '%s\n' "$_out"
    ;;

  status)
    if [ -f "$_SID_FILE" ]; then
      _sid=$(cat "$_SID_FILE")
      _queued=0
      _done=0
      [ -d "$_QUEUE_DIR" ] && _queued=$(find "$_QUEUE_DIR" -maxdepth 1 -name '*.json' -type f | wc -l)
      [ -d "$_DONE_DIR" ] && _done=$(find "$_DONE_DIR" -maxdepth 1 -name '*.json' -type f | wc -l)
      printf 'active thread: %s\n  queued: %d   done: %d\n' "$_sid" "$_queued" "$_done"
    else
      echo "no active thread (run: i/thread init)"
    fi
    ;;

  stop)
    if [ -f "$_SID_FILE" ]; then
      _sid=$(cat "$_SID_FILE")
      rm -f "$_SID_FILE"
      echo "thread stopped (sid=$_sid)"
    else
      echo "no active thread"
    fi
    ;;

  help|*)
    sed -n '2,18p' "$0"
    ;;
esac
