#!/usr/bin/env bash
# i/status -- default: brief substrate view; local diagnostic modes plus worker status modes.
#
# Local filesystem modes:
#   i/status state [mode=brief]
#   i/status timeline [window=5m]
#   i/status holograph [mode=trajectory]
#   i/status substrate [detail|actions|drift|consensus|efficacy|patterns|diff|invariants]
#   i/status team [show|summary|register|update|heartbeat|unregister]
#   i/status project [--json|--tag]
#   i/status forks [--json]
#   i/status decision-audit
#   i/status freeze [query]
#   i/status mode=patterns
#
# Worker modes still use the historical form:
#   i/status mode=coherence
#   i/status mode=self_audit
#   i/status mode=<worker-status-mode>
_ROOT="$(cd "$(dirname "$0")/.." && pwd)"
_REPO_ROOT="${PROJECT_ROOT:-${CLAUDE_PROJECT_DIR:-$_ROOT}}"
_HME_CLI="$_REPO_ROOT/scripts/hme-cli.js"
_HME_SCRIPTS="$_REPO_ROOT/scripts/hme"
_HME_TOOLS="$_REPO_ROOT/tools/HME/scripts"

_local_mode=""
case "${1:-}" in
  state|timeline|holograph|substrate|team|project|project-detect|forks|fork-watchdog|decision-audit|freeze|pattern|patterns)
    _local_mode="$1"
    shift
    ;;
esac

if [ -z "$_local_mode" ]; then
  for _a in "$@"; do
    case "$_a" in
      mode=state|mode=timeline|mode=holograph|mode=substrate|mode=team|mode=project|mode=project-detect|mode=forks|mode=fork-watchdog|mode=decision-audit|mode=freeze|mode=pattern|mode=patterns)
        _local_mode="${_a#mode=}"
        break
        ;;
    esac
  done
fi

_rest_without_mode() {
  _REST=()
  for _a in "$@"; do
    [ "$_a" = "mode=$_local_mode" ] && continue
    case "$_a" in
      submode=*) _REST+=("mode=${_a#submode=}") ;;
      view=*) _REST+=("mode=${_a#view=}") ;;
      brief=true) _REST+=("mode=brief") ;;
      trajectory=true) _REST+=("mode=trajectory") ;;
      pattern=*) _REST+=("${_a#pattern=}") ;;
      *) _REST+=("$_a") ;;
    esac
  done
}

_team_args() {
  _TEAM_ARGS=()
  for _a in "$@"; do
    if [[ "$_a" == *"="* && "$_a" != --* ]]; then
      _k="${_a%%=*}"
      _k="${_k//_/-}"
      _v="${_a#*=}"
      _TEAM_ARGS+=("--$_k" "$_v")
    else
      _TEAM_ARGS+=("$_a")
    fi
  done
}

if [ $# -eq 0 ] && [ -z "$_local_mode" ]; then
  exec python3 "$_HME_SCRIPTS/substrate-view.py" brief
fi

case "$_local_mode" in
  state)
    _rest_without_mode "$@"
    exec python3 "$_HME_SCRIPTS/state-panel.py" "${_REST[@]}"
    ;;
  timeline)
    _rest_without_mode "$@"
    exec python3 "$_HME_SCRIPTS/timeline-panel.py" "${_REST[@]}"
    ;;
  holograph)
    _rest_without_mode "$@"
    exec python3 "$_HME_SCRIPTS/holograph-panel.py" "${_REST[@]}"
    ;;
  substrate)
    _rest_without_mode "$@"
    exec python3 "$_HME_SCRIPTS/substrate-view.py" "${_REST[@]}"
    ;;
  team)
    _rest_without_mode "$@"
    _team_args "${_REST[@]}"
    exec python3 "$_HME_TOOLS/team_dashboard.py" "${_TEAM_ARGS[@]}"
    ;;
  project|project-detect)
    _rest_without_mode "$@"
    exec python3 "$_HME_TOOLS/project_detect.py" "${_REST[@]}"
    ;;
  forks|fork-watchdog)
    _rest_without_mode "$@"
    exec python3 "$_HME_TOOLS/fork_watchdog.py" "${_REST[@]}"
    ;;
  decision-audit)
    _rest_without_mode "$@"
    exec python3 "$_HME_TOOLS/decision_audit.py" "${_REST[@]}"
    ;;
  freeze)
    _rest_without_mode "$@"
    exec python3 "$_HME_SCRIPTS/freeze-check.py" "${_REST[@]}"
    ;;
  patterns)
    _rest_without_mode "$@"
    exec python3 "$_HME_SCRIPTS/substrate-view.py" patterns "${_REST[@]}"
    ;;
  pattern)
    _rest_without_mode "$@"
    exec python3 "$_HME_SCRIPTS/pattern-registry.py" "${_REST[@]}"
    ;;
esac

[ -f "$_HME_CLI" ] || { echo "i/: scripts/hme-cli.js missing at $_HME_CLI -- run scripts/setup-mcp.sh after cloning" >&2; exit 1; }
exec node "$_HME_CLI" status "$@"
