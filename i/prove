#!/usr/bin/env bash
# HME invariant prover — cross-file architectural invariant checker.
# Complements per-file ESLint rules with global/dataflow questions.
#
# Usage:
#   i/prove sole-writer target=<SYMBOL> allowed='<GLOB>'
#   i/prove no-import   from=<MODULE>  in='<GLOB>'
#   i/prove sole-caller function=<NAME> allowed='<GLOB>'
#
# Examples:
#   i/prove sole-writer target=couplingMatrix allowed='conductor/**'
#   i/prove no-import from=conductorIntelligence in='crossLayer/**'
#   i/prove sole-caller function=setBinaural allowed='play/grandFinale.js'
#
# Exit code: 0 if PROVEN, 1 if VIOLATED, 2 on usage error. Output is JSON
# on stdout with counterexamples when violated.
_REPO_ROOT="${CLAUDE_PROJECT_DIR:-/home/jah/Polychron}"
_PROVE_PY="$_REPO_ROOT/scripts/hme/prove.py"
if [ ! -f "$_PROVE_PY" ]; then
  echo "i/prove: $_PROVE_PY missing" >&2
  exit 2
fi
# Background activity emission so tool use shows up in blindspots/coverage
# metrics alongside i/review, i/hme-read, etc. Args are comma-joined into
# one field so the event log stays schema-friendly.
if [ -x "$_REPO_ROOT/tools/HME/activity/emit.py" ]; then
  _ARGS_JOINED=$(printf '%s ' "$@" | sed 's/ $//')
  PROJECT_ROOT="$_REPO_ROOT" python3 "$_REPO_ROOT/tools/HME/activity/emit.py" \
    --event=prove_invoked --args="$_ARGS_JOINED" >/dev/null &
fi
PROJECT_ROOT="$_REPO_ROOT" exec python3 "$_PROVE_PY" "$@"
