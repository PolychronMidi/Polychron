#!/usr/bin/env bash
# i/team -- team IPC coordination dashboard
# Usage: i/team [show|register|update|heartbeat|unregister|summary] ...
# Translate key=value args to --key value for the update subcommand.
_ARGS=()
for _a in "$@"; do
  if [[ "$_a" == *"="* ]] && [[ "$_a" != --* ]]; then
    _k="${_a%%=*}"
    _v="${_a#*=}"
    _ARGS+=("--${_k}" "$_v")
  else
    _ARGS+=("$_a")
  fi
done
exec python3 "$(dirname "$0")/../tools/HME/scripts/team_dashboard.py" "${_ARGS[@]}"
