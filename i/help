#!/usr/bin/env bash
# i/help — list every i/* tool grouped by category, with descriptions
# and usage strings. Reads tools/HME/i_registry.json for structured
# metadata; falls back to the line-2 header comment for any script not
# yet in the registry (drop-in convention preserved).
#
# Usage:
#   i/help                  list every command grouped by category
#   i/help <name>           detailed view of one command
#   i/help --json           dump the full metadata registry (machine-readable)

cd "$(dirname "$0")"
REPO_ROOT="${CLAUDE_PROJECT_DIR:-$(cd .. && pwd)}"
REGISTRY="$REPO_ROOT/tools/HME/i_registry.json"

if [ "$1" = "--json" ]; then
  cat "$REGISTRY"
  exit 0
fi

# Single-command detail view: `i/help review`
if [ -n "$1" ] && [ "$1" != "--all" ]; then
  python3 - "$REGISTRY" "$1" <<'PY'
import json, sys
reg_path, name = sys.argv[1], sys.argv[2]
with open(reg_path) as f:
    reg = json.load(f)
entry = reg.get("commands", {}).get(name)
if not entry:
    print(f"i/help: no registry entry for '{name}'", file=sys.stderr)
    sys.exit(1)
print(f"i/{name}")
print(f"  {entry.get('description', '(no description)')}")
print(f"  category: {entry.get('category', 'uncategorized')}")
if 'usage' in entry:
    print()
    print(f"  usage: {entry['usage']}")
if 'modes' in entry and entry['modes']:
    print()
    print(f"  modes: {', '.join(entry['modes'])}")
if 'examples' in entry and entry['examples']:
    print()
    print("  examples:")
    for ex in entry['examples']:
        print(f"    {ex}")
PY
  exit $?
fi

# Top-level: list every script grouped by registry category. Scripts not
# in the registry get listed under [unregistered] with their line-2
# header comment as the description (the legacy fallback).
python3 - "$REGISTRY" "$(pwd)" <<'PY'
import json, os, sys
reg_path, i_dir = sys.argv[1], sys.argv[2]
with open(reg_path) as f:
    reg = json.load(f)
commands = reg.get("commands", {})

scripts = sorted(f for f in os.listdir(i_dir)
                 if os.path.isfile(os.path.join(i_dir, f)) and not f.startswith('.'))

groups = {}  # category → [(name, description), ...]
for script in scripts:
    entry = commands.get(script)
    if entry:
        cat = entry.get("category", "uncategorized")
        desc = entry.get("description", "")
    else:
        cat = "unregistered"
        # Fallback: extract first non-shebang comment from the script.
        desc = ""
        try:
            with open(os.path.join(i_dir, script)) as f:
                for i, line in enumerate(f):
                    if i >= 5: break
                    s = line.strip()
                    if s.startswith("#") and not s.startswith("#!"):
                        desc = s.lstrip("#").strip()
                        break
        except OSError:
            pass
    groups.setdefault(cat, []).append((script, desc))

print("HME tool surface (i/):  use `i/help <name>` for detail")
print()

# Stable category order — known categories first, unregistered last.
cat_order = [
    "review-discipline", "knowledge", "diagnostic", "evolution",
    "policy-config", "infra", "orchestration", "meta", "uncategorized", "unregistered",
]
seen = set()
for cat in cat_order + sorted(groups.keys()):
    if cat in seen or cat not in groups: continue
    seen.add(cat)
    print(f"[{cat}]")
    for name, desc in groups[cat]:
        print(f"  {('i/' + name).ljust(16)}  {desc}")
    print()

print("See doc/HME.md for full reference.")
print("Tip: `i/help --json` dumps the full metadata for tab-completion / tooling.")
PY
