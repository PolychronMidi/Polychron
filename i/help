#!/usr/bin/env bash
# i/help — list all i/ tools with one-line descriptions.
# Generated from each tool's header comment (line 2).
cd "$(dirname "$0")"
printf "HME tool surface (i/):\n\n"
for tool in $(ls | grep -v '^help$' | sort); do
  # Extract the first non-shebang comment line from each tool
  desc=$(head -3 "$tool" 2>/dev/null | grep -m1 '^# ' | sed 's/^# *//')
  printf "  %-12s  %s\n" "i/$tool" "$desc"
done
printf "\nCommon modes:\n"
printf "  i/substrate [mode=brief|detail|actions|drift|consensus|efficacy|patterns|diff|invariants]\n"
printf "  i/substrate mode=invariants [filter=<substring>]   # browse the 169-entry registry\n"
printf "  i/pattern [list|matched|<id>]\n"
printf "  i/why <invariant-id>\n"
printf "  i/freeze [query-string-to-check-against-forbidden-list]\n"
printf "  i/hme-read target=<path|module|function> [mode=before|story|impact|both|lines|function|structure|callers|deps] [fast=true]\n"
printf "  i/trace target=<channel|module|beat-key> [mode=auto|cascade|module|causal|snapshot|impact|delta]\n"
printf "  i/status mode=list          # grouped catalogue of all 35+ status modes\n"
printf "  i/status mode=resume        # session briefing (git + pipeline + narrative)\n"
printf "  i/review [mode=digest|regime|trust|sections|audio|composition|health|forget|convention|symbols|docs|evolve|full]\n"
printf "  i/hme-admin action=<selftest|reload|restart|index|clear_index|warm|introspect|validate|fix_antipattern|health|both>\n"
printf "  i/learn [query=<q>|action=search|add|remove|list|compact|export|graph|dream|health|hypothesize|hypotheses|ground_truth]\n"
printf "\nSee doc/HME.md for full reference.\n"
