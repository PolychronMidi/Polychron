#!/usr/bin/env bash
# HME todo — hierarchical todo store with criticality + on-done triggers.
# Usage: i/todo action=list|add|done|... [text=…] [parent_id=N] [criticality=normal|critical]
_HME_CLI="$(dirname "$0")/../scripts/hme-cli.js"
[ -f "$_HME_CLI" ] || { echo "i/: scripts/hme-cli.js missing at $_HME_CLI — run scripts/setup-mcp.sh after cloning" >&2; exit 1; }
exec node "$_HME_CLI" hme_todo "$@"
