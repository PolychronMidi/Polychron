#!/usr/bin/env bash
# HME read — KB-briefed file read (KB constraints + callers + boundaries).
# Usage: i/hme-read target=<moduleName> [mode=auto|before]
_HME_CLI="$(dirname "$0")/../scripts/hme-cli.js"
[ -f "$_HME_CLI" ] || { echo "i/: scripts/hme-cli.js missing at $_HME_CLI — run scripts/setup-mcp.sh after cloning" >&2; exit 1; }
exec node "$_HME_CLI" read "$@"
