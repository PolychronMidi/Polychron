#!/usr/bin/env bash
# i/handoff — buddy hand-off lifecycle CLI.
#
# Usage:
#   i/handoff status                                    # primary + seniors + ctx %
#   i/handoff retire [reason="..."]                    # promote primary to senior
#   i/handoff promote sid=<sid> [floor=easy] [effort=low]  # designate sid as primary
#   i/handoff auto_retire_check                         # check threshold, retire if over
#   i/handoff consult sid=<senior-sid> question="..."   # manual senior invocation
#
# See doc/BUDDY_SYSTEM.md (Hand-off paradigm section).
_SCRIPT="$(dirname "$0")/../tools/HME/scripts/buddy_handoff.py"
[ -f "$_SCRIPT" ] || { echo "i/handoff: script missing at $_SCRIPT" >&2; exit 1; }

_ENV_FILE="$(dirname "$0")/../.env"
if [ -f "$_ENV_FILE" ]; then
  set -a
  # shellcheck disable=SC1090
  source "$_ENV_FILE"
  set +a
fi

_ARGS=()
_CMD="${1:-status}"
shift || true
for arg in "$@"; do
  case "$arg" in
    *=*)
      _key="${arg%%=*}"
      _val="${arg#*=}"
      _ARGS+=("--${_key//_/-}=${_val}")
      ;;
    *)
      _ARGS+=("$arg")
      ;;
  esac
done
exec python3 "$_SCRIPT" "$_CMD" "${_ARGS[@]}"
