#!/usr/bin/env bash
# i/audit -- umbrella for explicit audit, proof, blast-radius, and stress-check tools.
#
# Usage:
#   i/audit tiered [args...]
#   i/audit blast [--base HEAD~3] [--json] [--top N]
#   i/audit parallel [--phase N] [--json]
#   i/audit sensitivity
#   i/audit prove <invariant> <key=value>...
#   i/audit tools
_ROOT="$(cd "$(dirname "$0")/.." && pwd)"
_REPO_ROOT="${PROJECT_ROOT:-${CLAUDE_PROJECT_DIR:-$_ROOT}}"

_mode=""
case "${1:-}" in
  tiered|audit-tiered|blast|blast-radius|parallel|parallel-detect|sensitivity|metaprofile|prove|tools|audit-tools|surface)
    _mode="$1"
    shift
    ;;
esac

if [ -z "$_mode" ]; then
  for _a in "$@"; do
    case "$_a" in
      mode=*|action=*)
        _mode="${_a#*=}"
        ;;
    esac
    [ -n "$_mode" ] && break
  done
fi

_rest_without_selector() {
  _REST=()
  for _a in "$@"; do
    case "$_a" in
      mode=$_mode|action=$_mode) ;;
      *) _REST+=("$_a") ;;
    esac
  done
}

_usage() {
  cat <<'EOF'
i/audit modes:
  tiered       multi-pass cleanup orchestrator
  blast        cross-file blast-radius analyzer
  parallel     group SPEC phase items by file-overlap independence
  sensitivity  metaprofile attribution report
  prove        cross-file architectural invariant prover
  tools        isolated UX stress test for i/* command surface
EOF
}

case "$_mode" in
  tiered|audit-tiered)
    _rest_without_selector "$@"
    exec python3 "$_REPO_ROOT/tools/HME/scripts/tiered_audit.py" "${_REST[@]}"
    ;;
  blast|blast-radius)
    _rest_without_selector "$@"
    exec python3 "$_REPO_ROOT/tools/HME/scripts/blast_radius.py" "${_REST[@]}"
    ;;
  parallel|parallel-detect)
    _rest_without_selector "$@"
    exec python3 "$_REPO_ROOT/tools/HME/scripts/parallel_detect.py" "${_REST[@]}"
    ;;
  sensitivity|metaprofile)
    _rest_without_selector "$@"
    exec node "$_REPO_ROOT/scripts/metaprofile-sensitivity.js" "${_REST[@]}"
    ;;
  prove)
    _rest_without_selector "$@"
    exec python3 "$_REPO_ROOT/scripts/hme/prove.py" "${_REST[@]}"
    ;;
  tools|audit-tools|surface)
    _rest_without_selector "$@"
    exec python3 "$_REPO_ROOT/scripts/hme/audit-tool-surface.py" "${_REST[@]}"
    ;;
  ""|-h|--help|help)
    _usage
    exit 0
    ;;
  *)
    echo "i/audit: unknown mode '$_mode'" >&2
    _usage >&2
    exit 2
    ;;
esac
