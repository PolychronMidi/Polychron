#!/usr/bin/env bash
# i/audit-tools — UX stress test for the i/* CLI surface.
#
# Probes each registered tool with no-args + typo'd-action and rates
# the response shape against a UX rubric. Tools scoring < 4/5 are
# flagged for fix.
#
# SAFETY HISTORY: this tool crashed the host twice during initial
# development. Root cause: HME hooks fire backgrounded subprocesses
# via `(...) & disown` (see posttooluse_bash.sh:65, _lifesaver_bg in
# misc_safe.sh:76, _proxy_bridge.sh, etc.) which detach from the
# parent's process group and survive os.killpg(SIGKILL). Probing
# multiple tools accumulated those orphans into host-killing memory
# pressure.
#
# CURRENT ISOLATION: each probe now runs inside a transient
# `systemd-run --scope` cgroup with MemoryMax=512M, CPUQuota=100%,
# TasksMax=64, and RuntimeMaxSec={timeout+2}. cgroup-scoped kill
# cannot be escaped by `disown`/`setsid`/`nohup`/double-fork — every
# descendant is in the cgroup and dies atomically with the scope.
# Refuses to run if systemd-run is unavailable.
#
# Even with cgroup isolation, watch for runaway behavior on first run.
exec python3 "$(dirname "$0")/../scripts/hme/audit-tool-surface.py" "$@"
