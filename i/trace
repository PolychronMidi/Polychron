#!/usr/bin/env bash
# HME trace — causal/impact analysis and semantic search.
# Usage: i/trace target=<module|query> [mode=auto|impact|diagnose] [section=N] [limit=N]
_HME_CLI="$(dirname "$0")/../scripts/hme-cli.js"
[ -f "$_HME_CLI" ] || { echo "i/: scripts/hme-cli.js missing at $_HME_CLI — run scripts/setup-mcp.sh after cloning" >&2; exit 1; }
exec node "$_HME_CLI" trace "$@"
