#!/usr/bin/env bash
# i/decision-audit -- summarise architectural-edit audit rows from decision-audit.jsonl.
LOG="${PROJECT_ROOT:-/home/jah/Polychron}/output/metrics/decision-audit.jsonl"
[ -f "$LOG" ] || { echo "decision-audit: no log at $LOG (no architectural edits yet)"; exit 0; }
PROJECT_ROOT="${PROJECT_ROOT:-/home/jah/Polychron}" python3 - "$LOG" <<'PYEOF'
import json, sys
from collections import Counter
log = sys.argv[1]
total = 0
consulted = 0
by_file = Counter()
recent = []
with open(log) as f:
    for line in f:
        line = line.strip()
        if not line:
            continue
        try:
            d = json.loads(line)
        except json.JSONDecodeError:
            continue
        total += 1
        if d.get("consulted"):
            consulted += 1
        by_file[d.get("file", "?")] += 1
        recent.append(d)
recent = recent[-10:]
rate = (consulted / total * 100) if total else 0.0
print(f"decision-audit: {total} architectural edit(s) total, {consulted} with legacy advisor record ({rate:.1f}%)")
print()
print("most-touched architectural files:")
for f, n in by_file.most_common(5):
    print(f"  {n:>3}  {f}")
print()
print("most recent (last 10):")
for d in recent:
    flag = "C" if d.get("consulted") else " "
    print(f"  [{flag}] {d.get('ts', '?')}  {d.get('file', '?')}")
PYEOF
