#!/usr/bin/env bash
set -euo pipefail
ROOT="$(git rev-parse --show-toplevel)"
LOG="$ROOT/log/hme-post-commit-restart.log"
STATE="$ROOT/tools/HME/runtime/post-commit-proxy-reload-needed"
mkdir -p "$(dirname "$LOG")" "$(dirname "$STATE")"
HEAD_SHA="$(git -C "$ROOT" rev-parse --short HEAD 2>/dev/null || true)"
printf '%s\n' "$HEAD_SHA" >"$STATE"
printf '[post-commit] proxy reload needed for sha %s; not restarting synchronously from git hook\n' "$HEAD_SHA" >>"$LOG"
