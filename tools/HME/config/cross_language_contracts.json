    {
      "name": "MUTATING_EFFECTS",
      "values": ["write", "edit", "shell", "network", "agent"],
      "sites": [
        {
          "file": "tools/HME/omo_bridge/hme_tools_to_omo.py",
          "pattern": "MUTATING_EFFECTS\\s*=\\s*\\{([^}]+)\\}"
        },
        {
          "file": "tools/HME/omo_bridge/hme_tools_to_omo.js",
          "pattern": "MUTATING_EFFECTS\\s*=\\s*new\\s+Set\\(\\[([^\\]]+)\\]\\)"
        }
      ]
    }
  ],
  "function_pairs": [
    {
      "name": "hme_tools_to_omo:descriptor_transform",
      "py": {
        "file": "tools/HME/omo_bridge/hme_tools_to_omo.py",
        "symbol": "to_omo_tool_descriptor"
      },
      "js": {
        "file": "tools/HME/omo_bridge/hme_tools_to_omo.js",
        "symbol": "toOmoToolDescriptor"
      }
    }
  ],
  "schema_mirrors": [
    {
      "name": "ProjectAdapter",
      "schema": "tools/HME/config/project-adapter.schema.json",
      "dataclass_file": "tools/HME/scripts/project_adapter.py",
      "dataclass_name": "ProjectAdapter"
    }
  ]
}
