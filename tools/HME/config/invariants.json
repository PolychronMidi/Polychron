      "patterns": [
        "_trim_"
      ],
      "severity": "warning"
    },
    {
      "id": "hme-py-valueerror-coverage",
      "description": "OSError-only except handlers in operational_state.py must also catch ValueError (int/float conversion safety)",
      "type": "shell_output_empty",
      "shell": "grep -n 'except (OSError' tools/HME/mcp/server/operational_state.py | grep -v ValueError",
      "severity": "warning"
    },
    {
      "id": "nexus-review-issues-tracked",
      "description": "posttooluse_hme_review.sh must extract depth meter count and write REVIEW_ISSUES to nexus",
      "type": "patterns_all_in_file",
