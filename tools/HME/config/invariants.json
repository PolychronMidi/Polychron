      "severity": "error"
    },
    {
      "id": "activity-mode-in-status",
      "description": "status_unified must dispatch mode='activity' to activity_digest",
      "type": "pattern_in_file",
      "path": "tools/HME/mcp/server/tools_analysis/status_unified.py",
