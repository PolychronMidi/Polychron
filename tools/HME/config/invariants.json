    {
      "id": "hme-py-no-silent-catchall",
      "description": "HME Python files must not use silent `except Exception: pass` catch-all (swallows all errors). Matches both same-line and next-line forms, project-wide under tools/HME/mcp/server. Promoted to error after the 149-hit backlog was cleared \u2014 any new instance is a regression.",
      "type": "shell_output_empty",
      "shell": "python3 tools/HME/scripts/check-silent-except.py tools/HME/mcp/server",
      "severity": "error"
    },
    {
      "id": "hme-py-meta-has-trim",
      "description": "meta_observer.py must define a trim helper (_trim_) alongside its append-only file writes",
