{
  "_comment": "Project-specific rules consumed by HME tools and hooks. Logic stays in Python/bash; declarations live here.",

  "crosslayer_boundary_violations": [
    "conductorIntelligence.", "conductorState.",
    "systemDynamicsProfiler.", "pipelineCouplingManager."
  ],

  "known_l0_channels": [
    "onset", "note", "harmonic", "entropy", "coherence", "feedbackPitch",
    "regimeTransition", "rhythm", "tickDuration", "feedbackLoop",
    "motifIdentity", "phase", "spectral", "articulation", "grooveTransfer",
    "registerCollision", "convergence-density", "climax-pressure",
    "rest-sync", "density-rhythm", "section-quality", "emissionDelta",
    "perceptual-crowding", "harmonic-journey-eval", "emissionSummary",
    "phaseConvergence", "explainability", "emergentRhythm",
    "emergentDownbeat", "stutterContagion", "cadenceAlignment",
    "self-narration", "verticalCollision", "channel-coherence",
    "emergentMelody", "tension"
  ],

  "dry_patterns": [
    { "pattern": "(function deepFreeze", "message": "DRY: inline deepFreeze (use shared utility)" },
    { "pattern": "(function deepFreezeObj", "message": "DRY: inline deepFreeze (use shared utility)" },
    { "pattern": "=== 'L1' ? 'L2' : 'L1'", "message": "DRY: inline layer switch (use getOtherLayer)" }
  ],

  "doc_update_triggers": {
    "src/conductor/": ["doc/ARCHITECTURE.md (conductor changes)"],
    "src/crossLayer/": ["doc/ARCHITECTURE.md (cross-layer changes)"],
    "src/utils/": ["CLAUDE.md (new utility)"],
    "src/time/": ["doc/ARCHITECTURE.md (timing changes)"]
  },

  "known_non_tool_identifiers": [
    "done_signal", "max_iterations",
    "caused_by", "fixed_by", "depends_on", "contradicts", "similar_to", "supersedes",
    "architecture", "decision", "pattern", "bugfix",
    "_append_file_to_tab", "_extract_bg_output_path", "_tab_helpers",
    "pretooluse_bash", "pretooluse_edit", "pretooluse_grep", "pretooluse_write", "pretooluse_read",
    "posttooluse_bash", "posttooluse_write", "posttooluse_agent", "posttooluse_addknowledge",
    "posttooluse_hme_admin", "posttooluse_read", "posttooluse_edit",
    "posttooluse_hme_read", "posttooluse_hme_review", "posttooluse_pipeline_kb",
    "userpromptsubmit", "pretooluse_check_pipeline", "pretooluse_lifesaver",
    "_hme_enrich", "_hme_validate", "_hme_kb_count", "_hme_kb_titles",
    "_streak_tick", "_streak_check", "_streak_reset", "_safe_jq", "_safe_py3", "_safe_int",
    "_onb_is_graduated", "_onb_state", "_onb_advance", "_onb_sig",
    "_nexus_has", "_nexus_mark", "_nexus_clear", "_nexus_clear_type", "_nexus_pending",
    "cascade_prediction", "clap_tension", "encodec_entropy_avg",
    "hme_coherence", "hme_prediction_accuracy", "perceptual_complexity_avg",
    "fingerprint_verdict", "verdict_numeric",
    "coherence_violation", "edit_pending", "file_written", "inference_call",
    "jurisdiction_inject", "learn_suggested", "pipeline_run", "round_complete",
    "tool_use",
    "exploration_bonus", "productive_incoherence", "project_specificity",
    "read_coverage", "reflexivity_ratio", "staleness_penalty", "violation_penalty",
    "human_ground_truth", "ground_truth_override",
    "synthesis_reasoning", "synthesis_inference", "synthesis_llamacpp", "synthesis_pipeline",
    "synthesis_cascade", "synthesis_config", "synthesis_session", "synthesis_warm",
    "synthesis_gemini", "synthesis_groq", "synthesis_openrouter", "synthesis_cerebras",
    "synthesis_mistral", "synthesis_nvidia"
  ],

  "registration_patterns": [
    "conductorIntelligence.register",
    "crossLayerRegistry.register",
    "feedbackRegistry.register"
  ],

  "coupling_matrix_exempt_paths": [
    "/conductor/signal/balancing/",
    "/conductor/signal/profiling/",
    "/conductor/signal/meta/",
    "/conductor/signal/output/",
    "conductorDiagnostics",
    "/scripts/pipeline/",
    "/writer/traceDrain",
    "play/processBeat.js",
    "play/main.js",
    "play/crossLayerBeatRecord.js"
  ],

  "coupling_matrix_legacy_paths": [
    "phaseLockedRhythmGenerator.js",
    "conductorDampening.js",
    "densityWaveAnalyzer.js",
    "velocityShapeAnalyzer.js"
  ],

  "subsystem_names": [
    "conductor", "crossLayer", "composers", "rhythm", "fx", "time", "play", "writer"
  ],

  "line_count_thresholds": {
    "target": 200,
    "warn": 250,
    "critical": 300
  }
}
