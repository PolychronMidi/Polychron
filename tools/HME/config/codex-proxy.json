{
  "_doc": "Codex Responses proxy policy. The proxy is the Codex peer of the Claude Anthropic proxy: it preserves Codex's native request shape, observes prompt/tool size, can apply table-driven request shaping, and syncs update_plan calls into the HME TODO store.",
  "omniroute": {
    "enabled": true,
    "mode": "upstream",
    "url": "",
    "provider_prefix": "cx",
    "fallback_direct": true,
    "fallback_http_statuses": [400, 401, 403, 404, 429, 500, 502, 503, 504]
  },
  "todo_sync": {
    "enabled": true
  },
  "request_transform": {
    "instruction_append_file": "",
    "extra_instructions": "",
    "disabled_tools": [],
    "max_instruction_bytes_warn": 60000,
    "max_tool_count_warn": 80,
    "cleanup": {
      "enabled": true,
      "strip_success_hook_noise": true,
      "drop_empty_text_items": true
    },
    "payload_log": {
      "enabled": true,
      "preview_chars": 0
    }
  }
}
