{
  "description": "HyperMeta Ecstasy hooks — ALL events route through a single stateless forwarder (_proxy_bridge.sh) that POSTs to the proxy's /hme/lifecycle endpoint. All hook LOGIC lives in proxy-land (tools/HME/proxy/hook_bridge.js). The individual hook scripts in hooks/{lifecycle,pretooluse,posttooluse}/ are still invoked — but by the proxy, not by Claude Code directly. This is the single minimal coupling surface with Claude Code's plugin system.",
  "hooks": {
    "SessionStart": [
      {
        "hooks": [{"type": "command", "command": "bash ${CLAUDE_PLUGIN_ROOT}/hooks/_proxy_bridge.sh SessionStart", "timeout": 15}]
      }
    ],
    "PreToolUse": [
      {
        "hooks": [{"type": "command", "command": "bash ${CLAUDE_PLUGIN_ROOT}/hooks/_proxy_bridge.sh PreToolUse", "timeout": 15}]
      }
    ],
    "PostToolUse": [
      {
        "hooks": [{"type": "command", "command": "bash ${CLAUDE_PLUGIN_ROOT}/hooks/_proxy_bridge.sh PostToolUse", "timeout": 15}]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [{"type": "command", "command": "bash ${CLAUDE_PLUGIN_ROOT}/hooks/_proxy_bridge.sh UserPromptSubmit", "timeout": 15}]
      }
    ],
    "PreCompact": [
      {
        "hooks": [{"type": "command", "command": "bash ${CLAUDE_PLUGIN_ROOT}/hooks/_proxy_bridge.sh PreCompact", "timeout": 15}]
      }
    ],
    "PostCompact": [
      {
        "hooks": [{"type": "command", "command": "bash ${CLAUDE_PLUGIN_ROOT}/hooks/_proxy_bridge.sh PostCompact", "timeout": 15}]
      }
    ],
    "Stop": [
      {
        "hooks": [{"type": "command", "command": "bash ${CLAUDE_PLUGIN_ROOT}/hooks/_proxy_bridge.sh Stop", "timeout": 60}]
      }
    ],
    "StatusLine": [
      {
        "hooks": [{"type": "command", "command": "bash ${CLAUDE_PLUGIN_ROOT}/hooks/statusline.sh", "timeout": 5}]
      }
    ]
  }
}
