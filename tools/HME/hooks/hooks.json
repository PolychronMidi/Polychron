{
  "description": "HyperMeta Ecstasy hooks -- ALL Claude Code events route through node event_kernel/claude_adapter.js. Proxy-up mode POSTs to /hme/lifecycle; proxy-down mode calls the local event-kernel dispatcher directly. All Event -> hook routing lives in tools/HME/event_kernel/dispatcher.js. Claude Code never invokes individual hook handlers directly.",
  "hooks": {
    "SessionStart": [
      {
        "matcher": "startup",
        "hooks": [
          {
            "type": "command",
            "command": "node ${CLAUDE_PLUGIN_ROOT}/event_kernel/claude_adapter.js SessionStart",
            "timeout": 15
          }
        ]
      },
      {
        "matcher": "resume",
        "hooks": [
          {
            "type": "command",
            "command": "node ${CLAUDE_PLUGIN_ROOT}/event_kernel/claude_adapter.js SessionStart",
            "timeout": 15
          }
        ]
      },
      {
        "matcher": "clear",
        "hooks": [
          {
            "type": "command",
            "command": "node ${CLAUDE_PLUGIN_ROOT}/event_kernel/claude_adapter.js SessionStart",
            "timeout": 15
          }
        ]
      },
      {
        "matcher": "compact",
        "hooks": [
          {
            "type": "command",
            "command": "node ${CLAUDE_PLUGIN_ROOT}/event_kernel/claude_adapter.js SessionStart",
            "timeout": 15
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node ${CLAUDE_PLUGIN_ROOT}/event_kernel/claude_adapter.js PreToolUse",
            "timeout": 15
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node ${CLAUDE_PLUGIN_ROOT}/event_kernel/claude_adapter.js PostToolUse",
            "timeout": 15
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node ${CLAUDE_PLUGIN_ROOT}/event_kernel/claude_adapter.js UserPromptSubmit",
            "timeout": 15
          }
        ]
      }
    ],
    "PreCompact": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node ${CLAUDE_PLUGIN_ROOT}/event_kernel/claude_adapter.js PreCompact",
            "timeout": 15
          }
        ]
      }
    ],
    "PostCompact": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node ${CLAUDE_PLUGIN_ROOT}/event_kernel/claude_adapter.js PostCompact",
            "timeout": 15
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node ${CLAUDE_PLUGIN_ROOT}/event_kernel/claude_adapter.js Stop",
            "timeout": 60
          }
        ]
      }
    ],
    "StatusLine": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node ${CLAUDE_PLUGIN_ROOT}/event_kernel/statusline.js",
            "timeout": 5
          }
        ]
      }
    ]
  }
}
