{
  "description": "HyperMeta Ecstasy hooks -- host settings invoke event_kernel/host_hook_entry.js only; tools/HME/hooks plus event_kernel/dispatcher.js are the single source of hook routing truth.",
  "hooks": {
    "SessionStart": [
      {
        "matcher": "startup",
        "hooks": [
          {
            "type": "command",
            "command": "node ${CLAUDE_PLUGIN_ROOT}/event_kernel/host_hook_entry.js --host claude --event SessionStart",
            "timeout": 15
          }
        ]
      },
      {
        "matcher": "resume",
        "hooks": [
          {
            "type": "command",
            "command": "node ${CLAUDE_PLUGIN_ROOT}/event_kernel/host_hook_entry.js --host claude --event SessionStart",
            "timeout": 15
          }
        ]
      },
      {
        "matcher": "clear",
        "hooks": [
          {
            "type": "command",
            "command": "node ${CLAUDE_PLUGIN_ROOT}/event_kernel/host_hook_entry.js --host claude --event SessionStart",
            "timeout": 15
          }
        ]
      },
      {
        "matcher": "compact",
        "hooks": [
          {
            "type": "command",
            "command": "node ${CLAUDE_PLUGIN_ROOT}/event_kernel/host_hook_entry.js --host claude --event SessionStart",
            "timeout": 15
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node ${CLAUDE_PLUGIN_ROOT}/event_kernel/host_hook_entry.js --host claude --event PreToolUse",
            "timeout": 15
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node ${CLAUDE_PLUGIN_ROOT}/event_kernel/host_hook_entry.js --host claude --event PostToolUse",
            "timeout": 15
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node ${CLAUDE_PLUGIN_ROOT}/event_kernel/host_hook_entry.js --host claude --event UserPromptSubmit",
            "timeout": 15
          }
        ]
      }
    ],
    "PreCompact": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node ${CLAUDE_PLUGIN_ROOT}/event_kernel/host_hook_entry.js --host claude --event PreCompact",
            "timeout": 15
          }
        ]
      }
    ],
    "PostCompact": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node ${CLAUDE_PLUGIN_ROOT}/event_kernel/host_hook_entry.js --host claude --event PostCompact",
            "timeout": 15
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node ${CLAUDE_PLUGIN_ROOT}/event_kernel/host_hook_entry.js --host claude --event Stop",
            "timeout": 60
          }
        ]
      }
    ],
    "StatusLine": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node ${CLAUDE_PLUGIN_ROOT}/event_kernel/statusline.js",
            "timeout": 5
          }
        ]
      }
    ]
  }
}
