{
  "description": "HyperMeta Ecstasy hooks — only blocks Claude Code can't express via proxy middleware remain here",
  "hooks": {
    "SessionStart": [
      {
        "hooks": [{"type": "command", "command": "bash ${CLAUDE_PLUGIN_ROOT}/hooks/lifecycle/sessionstart.sh", "timeout": 10}]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "mcp__HME__status",
        "hooks": [{"type": "command", "command": "bash ${CLAUDE_PLUGIN_ROOT}/hooks/pretooluse/pretooluse_check_pipeline.sh", "timeout": 10}]
      },
      {
        "matcher": "mcp__HME__",
        "hooks": [{"type": "command", "command": "bash ${CLAUDE_PLUGIN_ROOT}/hooks/pretooluse/pretooluse_hme_primer.sh", "timeout": 5}]
      },
      {
        "matcher": "Edit",
        "hooks": [{"type": "command", "command": "bash ${CLAUDE_PLUGIN_ROOT}/hooks/pretooluse/pretooluse_edit.sh", "timeout": 10}]
      },
      {
        "matcher": "Write",
        "hooks": [{"type": "command", "command": "bash ${CLAUDE_PLUGIN_ROOT}/hooks/pretooluse/pretooluse_write.sh", "timeout": 10}]
      },
      {
        "matcher": "Bash",
        "hooks": [{"type": "command", "command": "bash ${CLAUDE_PLUGIN_ROOT}/hooks/pretooluse/pretooluse_bash.sh", "timeout": 10}]
      },
      {
        "matcher": "TodoWrite",
        "hooks": [{"type": "command", "command": "bash ${CLAUDE_PLUGIN_ROOT}/hooks/pretooluse/pretooluse_todowrite.sh", "timeout": 5}]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "",
        "hooks": [{"type": "command", "command": "bash ${CLAUDE_PLUGIN_ROOT}/hooks/log-tool-call.sh", "timeout": 10}]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {"type": "command", "command": "bash ${CLAUDE_PLUGIN_ROOT}/hooks/posttooluse/posttooluse_bash.sh", "timeout": 10},
          {"type": "command", "command": "bash ${CLAUDE_PLUGIN_ROOT}/hooks/posttooluse/posttooluse_pipeline_kb.sh", "timeout": 10}
        ]
      },
      {
        "matcher": "Edit",
        "hooks": [
          {"type": "command", "command": "bash ${CLAUDE_PLUGIN_ROOT}/hooks/posttooluse/posttooluse_edit.sh", "timeout": 10}
        ]
      },
      {
        "matcher": "Write",
        "hooks": [
          {"type": "command", "command": "bash ${CLAUDE_PLUGIN_ROOT}/hooks/posttooluse/posttooluse_write.sh", "timeout": 10}
        ]
      },
      {
        "matcher": "Agent",
        "hooks": [
          {"type": "command", "command": "bash ${CLAUDE_PLUGIN_ROOT}/hooks/posttooluse/posttooluse_agent.sh", "timeout": 10}
        ]
      },
      {
        "matcher": "mcp__HME__learn",
        "hooks": [
          {"type": "command", "command": "bash ${CLAUDE_PLUGIN_ROOT}/hooks/posttooluse/posttooluse_addknowledge.sh", "timeout": 10}
        ]
      },
      {
        "matcher": "mcp__HME__read",
        "hooks": [
          {"type": "command", "command": "bash ${CLAUDE_PLUGIN_ROOT}/hooks/posttooluse/posttooluse_hme_read.sh", "timeout": 10}
        ]
      },
      {
        "matcher": "mcp__HME__review",
        "hooks": [
          {"type": "command", "command": "bash ${CLAUDE_PLUGIN_ROOT}/hooks/posttooluse/posttooluse_hme_review.sh", "timeout": 10}
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [{"type": "command", "command": "bash ${CLAUDE_PLUGIN_ROOT}/hooks/lifecycle/userpromptsubmit.sh", "timeout": 10}]
      }
    ],
    "PreCompact": [
      {
        "hooks": [{"type": "command", "command": "bash ${CLAUDE_PLUGIN_ROOT}/hooks/lifecycle/precompact.sh", "timeout": 10}]
      }
    ],
    "PostCompact": [
      {
        "hooks": [{"type": "command", "command": "bash ${CLAUDE_PLUGIN_ROOT}/hooks/lifecycle/postcompact.sh", "timeout": 10}]
      }
    ],
    "Stop": [
      {
        "hooks": [{"type": "command", "command": "bash ${CLAUDE_PLUGIN_ROOT}/hooks/lifecycle/stop.sh", "timeout": 30}]
      }
    ]
  }
}
