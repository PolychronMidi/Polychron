{
  "_comment": "Metadata registry for the i/* command surface. Loaded by i/help and any future tab-completion / cross-discovery tooling. Adding a new command: drop the script in i/, register it here, done. Schema per command: {description, usage?, examples?, category, modes?}. Fields beyond description are optional \u2014 i/help degrades gracefully when missing.",
  "commands": {
    "review": {
      "description": "Post-change audit: KB constraints, boundary rules, doc drift, review verdicts.",
      "category": "review-discipline",
      "usage": "i/review [mode=digest|forget|...] [section_a=N] [section_b=N] [critique=true]",
      "modes": [
        "digest",
        "regime",
        "trust",
        "sections",
        "audio",
        "composition",
        "health",
        "forget",
        "convention",
        "symbols",
        "docs",
        "evolve",
        "full"
      ],
      "examples": [
        "i/review",
        "i/review mode=forget",
        "i/review mode=regime section_a=3 section_b=5"
      ],
      "safe_no_args": true
    },
    "learn": {
      "description": "HME knowledge base: add, search, list, compact, export, dream, hypothesize.",
      "category": "knowledge",
      "usage": "i/learn [query=<q>|action=search|add|remove|list|compact|export|graph|dream|health|hypothesize|hypotheses|ground_truth|discoveries|promote_discovery]",
      "modes": [
        "search",
        "add",
        "remove",
        "list",
        "compact",
        "export",
        "graph",
        "dream",
        "health",
        "hypothesize",
        "hypotheses",
        "ground_truth",
        "discoveries",
        "promote_discovery"
      ],
      "examples": [
        "i/learn query=\"regime self-balancer\"",
        "i/learn action=add title=\"...\" content=\"...\" category=pattern",
        "i/learn action=ground_truth title=R98 tags=[stable] content=\"verdict\""
      ],
      "safe_no_args": true
    },
    "trace": {
      "description": "Causal/impact analysis and semantic search across signals, modules, beats.",
      "category": "diagnostic",
      "usage": "i/trace target=<channel|module|beat-key> [mode=auto|cascade|module|causal|snapshot|impact|delta]",
      "modes": [
        "auto",
        "cascade",
        "module",
        "causal",
        "snapshot",
        "impact",
        "delta"
      ],
      "examples": [
        "i/trace target=density",
        "i/trace target=adaptiveTrustScores mode=cascade"
      ],
      "safe_no_args": true
    },
    "state": {
      "description": "Unified state panel — every state machine HME tracks, in one ~10-line view.",
      "category": "diagnostic",
      "usage": "i/state  |  i/state mode=brief",
      "modes": ["full (default)", "brief"],
      "examples": [
        "i/state",
        "i/state mode=brief"
      ],
      "safe_no_args": true
    },
    "status": {
      "description": "Status modes: budget, coherence, trajectory, resume, list, plus ~35 others.",
      "category": "diagnostic",
      "usage": "i/status [mode=<mode-name>]",
      "examples": [
        "i/status mode=list",
        "i/status mode=resume",
        "i/status mode=budget"
      ],
      "safe_no_args": true
    },
    "evolve": {
      "description": "Evolution recommendations: what to change next round, plus selftest.",
      "category": "evolution",
      "usage": "i/evolve [mode=...]",
      "examples": [
        "i/evolve"
      ],
      "safe_no_args": true
    },
    "hme-read": {
      "description": "Pre-edit briefing: read a target with KB context, callers, structure.",
      "category": "review-discipline",
      "usage": "i/hme-read target=<path|module|function> [mode=before|story|impact|both|lines|function|structure|callers|deps] [fast=true]",
      "modes": [
        "before",
        "story",
        "impact",
        "both",
        "lines",
        "function",
        "structure",
        "callers",
        "deps"
      ],
      "examples": [
        "i/hme-read target=adaptiveTrustScores",
        "i/hme-read target=src/conductor/conductorState.js mode=structure"
      ],
      "safe_no_args": true
    },
    "hme-admin": {
      "description": "Admin: selftest, reload, restart, index/clear_index, warm, introspect, validate, fix_antipattern, health.",
      "category": "infra",
      "usage": "i/hme-admin action=<selftest|reload|restart|index|clear_index|warm|introspect|validate|fix_antipattern|health|both>",
      "modes": [
        "selftest",
        "reload",
        "restart",
        "index",
        "clear_index",
        "warm",
        "introspect",
        "validate",
        "fix_antipattern",
        "health",
        "both"
      ],
      "examples": [
        "i/hme-admin action=health",
        "i/hme-admin action=index"
      ]
    },
    "hme": {
      "description": "Convenience wrapper that dispatches to other i/* tools by subcommand.",
      "category": "meta",
      "safe_no_args": true
    },
    "freeze": {
      "description": "Show arc-freeze marker; optionally check a query against the forbidden-pattern list.",
      "category": "review-discipline",
      "usage": "i/freeze [query-string]",
      "examples": [
        "i/freeze",
        "i/freeze \"never disable trust ceiling\""
      ],
      "safe_no_args": true
    },
    "pattern": {
      "description": "Pattern catalogue: list, matched, or fetch by id.",
      "category": "knowledge",
      "usage": "i/pattern [list|matched|<id>]"
    },
    "why": {
      "description": "Explain something the system did or is in: an invariant, a recent block, the onboarding state, a specific HCI verifier, an HCI drop, or recent hook activity.",
      "category": "review-discipline",
      "usage": "i/why <invariant-id>  |  i/why mode=<block|state|verifier|hci-drop|hook> [name=…]",
      "modes": ["invariant (default)", "block", "state", "verifier", "hci-drop", "hook"],
      "examples": [
        "i/why nexus-state-integrity",
        "i/why mode=block",
        "i/why mode=state",
        "i/why mode=verifier doc-drift",
        "i/why mode=hci-drop",
        "i/why mode=hook"
      ]
    },
    "todo": {
      "description": "Hierarchical todo store + SPEC/TODO bridge + KB devlog archive on set completion.",
      "category": "review-discipline",
      "usage": "i/todo <action> [text=...] [todo_id=N] [parent_id=N] [tier=easy|medium|hard] [critical=true]",
      "modes": [
        "list",
        "add",
        "done",
        "show",
        "update"
      ],
      "examples": [
        "i/todo list",
        "i/todo add text=\"refactor X\" tier=hard",
        "i/todo done todo_id=42",
        "i/todo ingest_from_spec",
        "i/todo close_with_spec_update todo_id=42",
        "i/todo phase_complete todo_id=2 text=\"Phase 2 complete: <summary>\"",
        "i/todo clear text=\"set name for archive\""
      ],
      "actions": [
        "list",
        "add",
        "done",
        "undo",
        "remove",
        "clear",
        "critical",
        "ingest_from_spec",
        "promote_to_spec",
        "close_with_spec_update",
        "phase_complete"
      ]
    },
    "substrate": {
      "description": "Substrate browser: brief, detail, actions, drift, consensus, efficacy, patterns, diff, invariants.",
      "category": "diagnostic",
      "usage": "i/substrate [mode=brief|detail|actions|drift|consensus|efficacy|patterns|diff|invariants] [filter=<substring>]",
      "modes": [
        "brief",
        "detail",
        "actions",
        "drift",
        "consensus",
        "efficacy",
        "patterns",
        "diff",
        "invariants"
      ],
      "safe_no_args": true
    },
    "policies": {
      "description": "Unified hook-time policy registry \u2014 list/show/enable/disable/reset/paths/eval.",
      "category": "policy-config",
      "usage": "i/policies <list|all|summary|show|enable|disable|reset|paths|eval> [args] [--scope=local|project|global]",
      "modes": [
        "list",
        "all",
        "summary",
        "show",
        "enable",
        "disable",
        "reset",
        "paths",
        "eval"
      ],
      "examples": [
        "i/policies list",
        "i/policies all",
        "i/policies summary",
        "i/policies disable block-curl-pipe-sh"
      ]
    },
    "extract-spec": {
      "description": "Extract a structured spec for a target module/feature for evolution planning.",
      "category": "evolution",
      "safe_no_args": true
    },
    "prove": {
      "description": "Cross-file architectural invariant prover. Complements per-file ESLint rules with global/dataflow questions.",
      "category": "review-discipline",
      "safe_no_args": true
    },
    "help": {
      "description": "List all i/ tools grouped by category, with descriptions and usage.",
      "category": "meta"
    },
    "sensitivity": {
      "description": "Metaprofile attribution aggregator \u2014 per-profile score distribution, per-(profile, sectionType) breakdown, and ranking by mean score.",
      "category": "diagnostic",
      "usage": "i/sensitivity",
      "examples": [
        "i/sensitivity"
      ],
      "safe_no_args": true
    },
    "buddy": {
      "description": "DEPRECATED \u2014 alias for i/dispatch. Use i/dispatch for new code. Preserved so existing callers + transcripts keep working.",
      "category": "orchestration",
      "usage": "i/buddy <status|enqueue|drain|clean|chain> [key=value ...]  (forwards to i/dispatch)",
      "examples": [
        "i/buddy status  # equivalent to: i/dispatch status"
      ]
    },
    "chain": {
      "description": "Run an ordered Bash-skill chain from chains/<name>.yaml. Independent of BUDDY_SYSTEM.",
      "category": "orchestration",
      "usage": "i/chain <chain-name> [loop=N] [on_rate_limit=fail|pause|pause-with-cap]",
      "examples": [
        "i/chain review-then-test",
        "i/chain dev-cycle loop=3",
        "i/chain overnight on_rate_limit=pause-with-cap"
      ]
    },
    "dispatch": {
      "description": "Task dispatcher CLI (queue + worker routing). Subactions: status / enqueue / drain / clean / chain. Routes via HME_DISPATCH_MODE (claude-resume / synthesis / disabled).",
      "category": "orchestration",
      "usage": "i/dispatch <status|enqueue|drain|clean|chain> [key=value ...]",
      "examples": [
        "i/dispatch status",
        "i/dispatch enqueue tier=medium text=\"address review finding\" source=i/review",
        "i/dispatch drain loop=true loop_delay=5",
        "i/dispatch chain review-then-test"
      ]
    },
    "audit-tools": {
      "description": "UX stress test for i/* CLI surface. Each probe runs inside a transient systemd-run --scope cgroup (MemoryMax=512M, TasksMax=64) so disown'd/double-forked descendants of HME posttooluse hooks die atomically with the scope. Crashed the host twice before this isolation landed; treat with caution on first re-enable.",
      "category": "meta",
      "usage": "i/audit-tools"
    }
  }
}