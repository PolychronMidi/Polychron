{
  "mcpServers": {
    "HME": {
      "type": "stdio",
      "command": "python3",
      "args": ["server/main.py"],
      "env": {
        "PROJECT_ROOT": "",
        "HF_HUB_OFFLINE": "1",
        "TRANSFORMERS_OFFLINE": "1",
        "PYTHONPATH": ""
      },
      "ragIgnoreDirs": [
        ".git", ".claude", "node_modules", "__pycache__",
        "venv", ".venv", "dist", "build", "output", "tmp", "lab", "runtime"
      ],
      "ragIgnore": [
        "*.log", "*-lock.yaml", "*.json", "*.wav", "*.mid", "*.csv"
      ],
      "ragLibs": [],
      "ragMaxFileSize": 512
    }
  }
}
