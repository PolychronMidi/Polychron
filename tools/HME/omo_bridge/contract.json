{
  "contract_version": "hme-opencode-hook/v1",
  "dependency_contract_version": "hme-omo/v1",
  "universal_hook_abi": {
    "version": "hme-opencode-hook/v1",
    "core_phases": [
      "chat.params",
      "chat.headers",
      "permission.ask",
      "tool.execute.before",
      "tool.execute.after"
    ],
    "hme_extension_phases": [
      "stop.before",
      "stream.text_block"
    ],
    "observational_phases": [
      "experimental.chat.messages.transform",
      "experimental.chat.system.transform",
      "session.start",
      "session.end",
      "message.input",
      "message.output",
      "stream.delta",
      "policy.evaluate",
      "telemetry.event"
    ],
    "decision_kinds": [
      "allow",
      "deny",
      "modify",
      "rewrite",
      "drop",
      "inject",
      "ask_permission",
      "defer"
    ]
  },
  "required_entrypoints": [
    "package.json",
    "dist/index.js",
    "dist/features/context-injector/index.d.ts",
    "dist/hooks/anthropic-context-window-limit-recovery/index.d.ts",
    "dist/config/schema/dynamic-context-pruning.d.ts",
    "dist/plugin-interface.d.ts"
  ],
  "optional_entrypoints": [
    "dist/features/team-mode",
    "dist/features/background-agent",
    "dist/plugin-handlers/index.d.ts"
  ]
}
