{
  "permissions": {
    "deny": [
      "Bash(rm*run.lock*)",
      "Bash(*rm*run.lock*)"
    ]
  },
  "hooks": {
    "SessionStart": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "bash tools/HME/hooks/sessionstart.sh"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "bash tools/HME/hooks/pretooluse_lifesaver.sh"
          }
        ]
      },
      {
        "matcher": "Edit",
        "hooks": [
          {
            "type": "command",
            "command": "bash tools/HME/hooks/pretooluse_edit.sh"
          }
        ]
      },
      {
        "matcher": "Grep",
        "hooks": [
          {
            "type": "command",
            "command": "bash tools/HME/hooks/pretooluse_grep.sh"
          }
        ]
      },
      {
        "matcher": "Write",
        "hooks": [
          {
            "type": "command",
            "command": "bash tools/HME/hooks/pretooluse_write.sh"
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash tools/HME/hooks/pretooluse_bash.sh"
          }
        ]
      },
      {
        "matcher": "Read",
        "hooks": [
          {
            "type": "command",
            "command": "bash tools/HME/hooks/pretooluse_read.sh"
          }
        ]
      },
      {
        "matcher": "mcp__HME__check_pipeline",
        "hooks": [
          {
            "type": "command",
            "command": "bash tools/HME/hooks/pretooluse_check_pipeline.sh"
          }
        ]
      },
      {
        "matcher": "mcp__HME__",
        "hooks": [
          {
            "type": "command",
            "command": "bash tools/HME/hooks/pretooluse_hme_primer.sh"
          }
        ]
      },
      {
        "matcher": "TodoWrite",
        "hooks": [
          {
            "type": "command",
            "command": "bash tools/HME/hooks/pretooluse_todowrite.sh"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "bash tools/HME/hooks/log-tool-call.sh"
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash tools/HME/hooks/posttooluse_bash.sh"
          },
          {
            "type": "command",
            "command": "bash tools/HME/hooks/posttooluse_pipeline_kb.sh"
          }
        ]
      },
      {
        "matcher": "Read",
        "hooks": [
          {
            "type": "command",
            "command": "bash tools/HME/hooks/posttooluse_read.sh"
          }
        ]
      },
      {
        "matcher": "Write",
        "hooks": [
          {
            "type": "command",
            "command": "bash tools/HME/hooks/posttooluse_write.sh"
          }
        ]
      },
      {
        "matcher": "Agent",
        "hooks": [
          {
            "type": "command",
            "command": "bash tools/HME/hooks/posttooluse_agent.sh"
          }
        ]
      },
      {
        "matcher": "Edit",
        "hooks": [
          {
            "type": "command",
            "command": "bash tools/HME/hooks/posttooluse_edit.sh"
          }
        ]
      },
      {
        "matcher": "mcp__HME__read",
        "hooks": [
          {
            "type": "command",
            "command": "bash tools/HME/hooks/posttooluse_hme_read.sh"
          }
        ]
      },
      {
        "matcher": "mcp__HME__review",
        "hooks": [
          {
            "type": "command",
            "command": "bash tools/HME/hooks/posttooluse_hme_review.sh"
          }
        ]
      },
      {
        "matcher": "mcp__HME__add_knowledge",
        "hooks": [
          {
            "type": "command",
            "command": "bash tools/HME/hooks/posttooluse_addknowledge.sh"
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "bash tools/HME/hooks/userpromptsubmit.sh"
          }
        ]
      }
    ],
    "PreCompact": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "bash tools/HME/hooks/precompact.sh"
          }
        ]
      }
    ],
    "PostCompact": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "bash tools/HME/hooks/postcompact.sh"
          }
        ]
      }
    ],
    "Stop": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "bash tools/HME/hooks/stop.sh"
          }
        ]
      }
    ]
  }
}
