/tools/*/__pycache__/
/tools/*/global_kb/
/tools/**/__pycache__/
/tools/HME/session-state.json
/tools/HME/mcp/db/
/tools/HME/mcp/*.db
/tools/HME/mcp/metrics/
/tools/HME/proxy/metrics/
/tools/HME/chat/metrics/
/tools/HME/chat/log/
/tools/HME/chat/src/log/
/tools/HME/chat/webview/log/
/scripts/pipeline/metrics/
/scripts/pipeline/log/
/scripts/pipeline/hme/log/
/tools/HME/warm-context-cache/*.json
/tools/models
*.bak
log/

# metrics - track only intentional files (journal, adaptive-state, named snapshots)
/metrics/run-history/
/metrics/vram-history.jsonl

# KB lance tables — ephemeral generated state, never hand-authored.
# The .lance directories are regenerated by rag_engines indexing and compacted
# by scripts/compact-lance-tables.py. Tracking their internals (_deletions/,
# _transactions/, _versions/, data/) produces gigabytes of binary drift per
# indexer run and causes patch-based commit tools (GitLens) to fail with
# "cannot apply binary patch ... without full index line" when pre-image
# SHAs drift. Gitignored en masse.
/tools/HME/KB/*.lance/
